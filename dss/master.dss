! ============================================================================
! master.dss — Western Cape 11 kV Feeder Protection Study
! Section 2: Pre-SSEG baseline
! ============================================================================

Clear
Set DefaultBaseFrequency=50

Redirect network.dss
Redirect loads.dss

! sseg.dss disabled — pre-SSEG baseline
! Redirect sseg.dss

Redirect protection.dss

Set Mode=Snapshot
Solve
